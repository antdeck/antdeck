<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Live News Dashboard</title>
    <style>
        body { 
            margin: 0; display: flex; height: 100vh; background: #121212;
            overflow-x: auto; overflow-y: hidden; font-family: sans-serif;
        }
        .column {
            min-width: 380px; height: 100%; border-right: 2px solid #333;
            display: flex; flex-direction: column; background: #fff;
        }
        .label {
            background: #202124; color: #bdc1c6; font-size: 10px;
            padding: 5px; text-align: center; font-weight: bold;
            border-bottom: 1px solid #000;
        }
        iframe { 
            width: 100%; height: 100%; border: none;
            /* Shrinks font/content scale */
            zoom: 0.75; -moz-transform: scale(0.75); -moz-transform-origin: 0 0;
        }
    </style>
</head>
<body>

    <script>
        // Update these 20 terms to whatever you want to monitor
        const topics = [
            "State of Emergency", "disaster declaration", "evacuation", "shelter in place", "lockdown", "police activity", "law enforcement activity", "gas leak", "ammonia leak", "landslide", "water main break", "boil water notice", "vehicle AND (crash OR accident)", "widespread outages", "raising canes shooting", "raising canes police", "home depot police", "home depot law enforcement"
        ];

        topics.forEach((term, index) => {
            const col = document.createElement('div');
            col.className = 'column';
            
            // tbm=nws -> Switches to Google News
            // tbs=sbd:1 -> Sorts by Date (Most Recent)
            // igu=1 -> Allows embedding in iframes
            const baseUrl = `https://www.google.com/search?q=${encodeURIComponent(term)}&tbm=nws&tbs=sbd:1&igu=1`;

            col.innerHTML = `
                <div class="label">${index + 1} | ${term.toUpperCase()} (LATEST)</div>
                <iframe id="frame-${index}" src="${baseUrl}"></iframe>
            `;
            document.body.appendChild(col);

            // 5-Minute Refresh (300,000ms)
            setInterval(() => {
                const frame = document.getElementById(`frame-${index}`);
                // Add timestamp to force a fresh pull of the latest news
                frame.src = baseUrl + "&t=" + new Date().getTime();
            }, 300000); 
        });
    </script>

</body>
</html>
